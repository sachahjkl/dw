{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sachahjkl/dw/schemas/release.schema.json",
  "title": "dw release manifest",
  "type": "object",
  "required": ["schema", "version", "commit", "channel", "assets"],
  "properties": {
    "schema": {
      "const": 1
    },
    "version": {
      "type": "string"
    },
    "commit": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rid", "fileName", "sha256"],
        "properties": {
          "rid": {
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
