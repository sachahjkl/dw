{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.4-mini",
  "small_model": "github-copilot/gpt-5.4-mini",
  "instructions": [
    "C:\\Users\\froment\\.agents\\CONTEXT.md",
    "C:\\Users\\froment\\.agents\\OGF_WORKFLOW.md"
  ],
  "permission": {
    "websearch": "deny",
    "lsp": "allow",
    "skill": "allow",
    "task": {
      "*": "ask",
      "explore": "allow",
      "ado-orchestrator": "allow",
      "ogf-code-reviewer": "allow",
      "ogf-text-ops": "allow"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "pnpm *": "allow",
      "dotnet *": "allow",
      "*.ps1 *": "allow"
    },
    "external_directory": {
      "S:\\ai-agent-workdir\\ws\\.anchors": "allow",
      "S:\\ai-agent-workdir\\ws\\.anchors\\**": "allow",
      "C:\\Users\\froment\\.agents\\skills\\ado-workitem\\references\\worktree-tools": "allow"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.4",
      "permission": {
        "task": {
          "*": "ask",
          "explore": "allow",
          "ogf-code-reviewer": "allow",
          "ogf-text-ops": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": {
          "explore": "allow",
          "ogf-text-ops": "allow"
        }
      }
    }
  },
  "mcp": {
    "exa-websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem@latest",
        "S:\\"
      ]
    },
    "ado": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp@next",
        "digital-factory-ogf"
      ],
      "environment": {
        "LOG_LEVEL": "debug"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  },
  "shell": "pwsh"
}
